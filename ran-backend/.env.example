# Core runtime
NODE_ENV=development
PORT=3000

# Session / cookies
COOKIE=ran.sid
SESSION_SECRET=change-this-in-production

# CORS origins (comma-separated, no trailing slash)
WEB_URL=http://localhost:3001

# Production only — cookie domain for cross-subdomain auth (e.g. .rng-dev.com)
# Leave unset for local development
COOKIE_DOMAIN=

# Production only — public backend base URL for upload URL generation
# Leave unset for local development
BACKEND_URL=

# Database server
DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=sa
DB_PASS=your-db-password

# Database names
DB_NAME_WEB=OrenjiWeb
DB_NAME_GAME=RG2Game
DB_NAME_SHOP=RG2Shop
DB_NAME_LOG=RG2Log
DB_NAME_USER=RG2User

# Legacy auth toggle (string "true"/"false")
IsMD5=true

# reCAPTCHA — server-side secret key (from console.cloud.google.com/recaptcha)
# Leave unset to skip captcha verification (e.g. local development)
RECAPTCHA_SECRET_KEY=

# Optional
SENTRY_DSN=
ENABLE_SWAGGER=false
